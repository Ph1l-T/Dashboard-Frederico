def configure() {
  log.debug "configure()"
}

def installed() {
  sendEvent(name: "numberOfButtons", value: 24)
  log.debug "installed()"
  off()
  setdefaults()
}

def updated() {
  log.debug "updated()"
  setdefaults()
  off()
  AtualizaDadosGW3()
}

// Get Device info and set as state to use during driver
def AtualizaDadosGW3() {
  state.currentip = settings.molIPAddress
  state.serialNum = settings.serialNum
  state.verifyCode = settings.verifyCode
  state.channel = settings.channel
  
  log.info "GW3 Dados atualizados - IP: ${state.currentip}, Serial: ${state.serialNum}"
}

// Default values
def setdefaults() {
  sendEvent(name: "tvCommand", value: "OFF", descriptionText: "TV command set to OFF")
  sendEvent(name: "switch", value: "off")
  log.debug "Defaults set"
}

// Comandos principais (Power)
def on() {
  log.info "Ligando TV..."
  sendEvent(name: "switch", value: "on")
  sendEvent(name: "tvCommand", value: "ON")
  EnviaComando(IR_CODES['ON'])
}


def off() {
  log.info "Desligando TV..."
  sendEvent(name: "switch", value: "off")
  sendEvent(name: "tvCommand", value: "OFF")
  EnviaComando(IR_CODES['OFF'])
}


def commandON() {
  on()
}


def commandOFF() {
  off()
}

// Funções auxiliares
private void sendTvCommand(String label, String key) {
  log.info "Comando TV: ${label}"
  sendEvent(name: "tvCommand", value: label)
  EnviaComando(IR_CODES[key])
}

// Comandos de canal
def chUp()      { sendTvCommand("CH_UP",      'CH_UP') }
def chDown()    { sendTvCommand("CH_DOWN",    'CH_DOWN') }

// Outros comandos principais
def tvReturn()  { sendTvCommand("RETURN",     'RETURN') }
def menu()      { sendTvCommand("MENU",       'MENU') }
def mute()      { sendTvCommand("MUTE",       'MUTE') }
def home()      { sendTvCommand("HOME",       'HOME') }

// Cursor
def cursorUp()    { sendTvCommand("CUR_UP",    'CUR_UP') }
def cursorDown()  { sendTvCommand("CUR_DOWN",  'CUR_DOWN') }
def cursorLeft()  { sendTvCommand("CUR_LEFT",  'CUR_LEFT') }
def cursorRight() { sendTvCommand("CUR_RIGHT", 'CUR_RIGHT') }
